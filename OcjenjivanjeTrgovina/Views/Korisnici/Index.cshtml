@model IEnumerable<OcjenjivanjeTrgovina.Models.Korisnik>

@{
    ViewData["Title"] = "Korisnici";
    var korisnikList = Model.ToList();
}

<div class="container-fluid py-5">
    <div class="row mb-5">
        <div class="col-lg-8">
            <h1 class="display-4 fw-bold mb-2">
                <i class="bi bi-people"></i> Korisnici
            </h1>
            <p class="text-muted fs-5">Pregledajte sve registrirane korisnike i njihove profile</p>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="input-group input-group-lg">
                <span class="input-group-text bg-light border-0">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" class="form-control form-control-lg border-start-0" 
                       placeholder="Pretraži korisnike po imenu ili emailu..." id="searchInput">
            </div>
        </div>
    </div>

    @if (!korisnikList.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-inbox" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Nema dostupnih korisnika</h4>
        </div>
    }
    else
    {
        <div class="row g-4" id="usersGrid">
            @foreach (var korisnik in korisnikList)
            {
                <div class="col-lg-6 col-xl-4 korisnik-card" data-search="@($"{korisnik.Ime} {korisnik.Prezime} {korisnik.Email}".ToLower())">
                    <div class="card h-100 shadow-sm border-0 position-relative overflow-hidden transition">
                        <div class="position-absolute top-0 end-0 p-3">
                            <span class="badge bg-primary">ID: @korisnik.Id</span>
                        </div>

                        <div class="card-body pb-2">
                            <h5 class="card-title fw-bold mb-2" style="color: #2c3e50;">
                                <i class="bi bi-person-circle text-primary"></i> @korisnik.Ime @korisnik.Prezime
                            </h5>

                            <p class="mb-2">
                                <i class="bi bi-envelope"></i>
                                <a href="mailto:@korisnik.Email" class="text-decoration-none">@korisnik.Email</a>
                            </p>

                            <p class="mb-2">
                                <i class="bi bi-telephone"></i>
                                <a href="tel:@korisnik.Telefon" class="text-decoration-none">@korisnik.Telefon</a>
                            </p>

                            <p class="small text-muted mb-0">
                                <i class="bi bi-calendar"></i>
                                Registracija: @korisnik.DatumRegistracije.ToString("d.M.yyyy")
                            </p>
                        </div>

                        <div class="card-footer bg-light border-0 p-3">
                            <a href="@Url.Action("Details", "Korisnik", new { id = korisnik.Id })" class="btn btn-sm btn-primary w-100">
                                <i class="bi bi-eye"></i> Pogledaj Profil
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition { transition: all 0.3s ease; }
    .card:hover { transform: translateY(-8px); box-shadow: 0 12px 28px rgba(0, 0, 0, 0.15) !important; }
</style>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', filterUsers);

        function filterUsers() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const cards = document.querySelectorAll('.korisnik-card');

            cards.forEach(card => {
                const searchData = card.getAttribute('data-search');
                card.style.display = searchData.includes(searchTerm) ? '' : 'none';
            });
        }
    </script>
}
