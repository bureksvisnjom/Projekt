@model OcjenjivanjeTrgovina.Models.Trgovina

@{
    ViewData["Title"] = "Kreiraj Novu Trgovinu";
}

<div class="container-fluid py-5">
    <!-- Breadcrumb Navigation -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" class="text-decoration-none">
                    <i class="bi bi-house"></i> Početna
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index")" class="text-decoration-none">
                    <i class="bi bi-shop"></i> Trgovine
                </a>
            </li>
            <li class="breadcrumb-item active">Kreiraj Novu</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Header -->
            <div class="mb-5">
                <h1 class="display-5 fw-bold mb-2">
                    <i class="bi bi-plus-circle text-primary"></i> Kreiraj Novu Trgovinu
                </h1>
                <p class="text-muted fs-5">Unesite podatke za novu trgovinu u sistem</p>
            </div>

            <!-- Form Card -->
            <div class="card shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-body p-5">
                    <form asp-action="Create" method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-circle"></i>
                            <strong class="ms-2">Greške pri validaciji!</strong>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvori"></button>
                        </div>

                        <!-- Naziv -->
                        <div class="mb-4">
                            <label asp-for="Naziv" class="form-label fw-bold">
                                <i class="bi bi-shop"></i> Naziv Trgovine
                            </label>
                            <input asp-for="Naziv" class="form-control form-control-lg" 
                                   placeholder="npr. Trgovina Prima" required>
                            <span asp-validation-for="Naziv" class="text-danger small"></span>
                            <small class="form-text text-muted">Unesite naziv vaše trgovine</small>
                        </div>

                        <!-- Adresa -->
                        <div class="mb-4">
                            <label asp-for="Adresa" class="form-label fw-bold">
                                <i class="bi bi-geo-alt"></i> Adresa
                            </label>
                            <input asp-for="Adresa" class="form-control form-control-lg" 
                                   placeholder="npr. Trg bana Jelačića 10" required>
                            <span asp-validation-for="Adresa" class="text-danger small"></span>
                            <small class="form-text text-muted">Unesite adresu trgovine</small>
                        </div>

                        <!-- Grad -->
                        <div class="mb-4">
                            <label asp-for="Grad" class="form-label fw-bold">
                                <i class="bi bi-building"></i> Grad
                            </label>
                            <input asp-for="Grad" class="form-control form-control-lg" 
                                   placeholder="npr. Zagreb" list="gradovList" required>
                            <datalist id="gradovList">
                                <option value="Zagreb"></option>
                                <option value="Split"></option>
                                <option value="Rijeka"></option>
                                <option value="Osijek"></option>
                                <option value="Zadar"></option>
                            </datalist>
                            <span asp-validation-for="Grad" class="text-danger small"></span>
                            <small class="form-text text-muted">Unesite grad u kojem se nalazi trgovina</small>
                        </div>

                        <!-- Datum Otvaranja -->
                        <div class="mb-4">
                            <label asp-for="DatumOtvaranja" class="form-label fw-bold">
                                <i class="bi bi-calendar-event"></i> Datum Otvaranja
                            </label>
                            <input asp-for="DatumOtvaranja" type="date" class="form-control form-control-lg" required>
                            <span asp-validation-for="DatumOtvaranja" class="text-danger small"></span>
                            <small class="form-text text-muted">Odaberite datum otvaranja trgovine</small>
                        </div>

                        <!-- Telefon -->
                        <div class="mb-4">
                            <label asp-for="Telefon" class="form-label fw-bold">
                                <i class="bi bi-telephone"></i> Telefon
                            </label>
                            <input asp-for="Telefon" type="tel" class="form-control form-control-lg" 
                                   placeholder="npr. 014880123" required>
                            <span asp-validation-for="Telefon" class="text-danger small"></span>
                            <small class="form-text text-muted">Unesite telefonski broj</small>
                        </div>

                        <!-- Email -->
                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-bold">
                                <i class="bi bi-envelope"></i> Email
                            </label>
                            <input asp-for="Email" type="email" class="form-control form-control-lg" 
                                   placeholder="npr. prima@example.com" required>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                            <small class="form-text text-muted">Unesite email adresu</small>
                        </div>

                        <!-- Form Actions -->
                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle"></i> Kreiraj Trgovinu
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-arrow-left"></i> Otkaži
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Info Alert -->
            <div class="alert alert-info mt-4 border-0" role="alert" style="border-radius: 12px;">
                <i class="bi bi-info-circle"></i>
                <strong class="ms-2">Info:</strong>
                <span class="ms-2">Svi polja su obavezna. Provjerite podatke prije kreiranja.</span>
            </div>
        </div>
    </div>
</div>

<!-- CSS Styling -->
<style>
    .form-control,
    .form-select {
        border-radius: 8px;
        border: 1px solid #dee2e6;
        transition: all 0.3s ease;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
    }

    .form-label {
        color: #2c3e50;
        margin-bottom: 0.5rem;
    }

    .btn-lg {
        padding: 0.75rem 1.5rem;
        font-size: 1rem;
        border-radius: 8px;
    }

    .breadcrumb {
        background-color: #f8f9fa;
        border-radius: 8px;
    }

    .card {
        transition: all 0.3s ease;
    }

    .card:hover {
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1) !important;
    }

    @media (max-width: 768px) {
        .display-5 {
            font-size: 2rem;
        }

        .card-body {
            padding: 1.5rem !important;
        }
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
