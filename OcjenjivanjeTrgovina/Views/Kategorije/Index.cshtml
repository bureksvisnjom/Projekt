@model IEnumerable<OcjenjivanjeTrgovina.Models.Kategorija>

@{
    ViewData["Title"] = "Kategorije";
    var kategorijeList = Model.ToList();
}

<div class="container-fluid py-5">
    <div class="row mb-5">
        <div class="col-lg-8">
            <h1 class="display-4 fw-bold mb-2">
                <i class="bi bi-tags"></i> Kategorije
            </h1>
            <p class="text-muted fs-5">Pregledajte sve dostupne kategorije proizvoda</p>
        </div>
    </div>

    @if (!kategorijeList.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-inbox" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Nema dostupnih kategorija</h4>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var kategorija in kategorijeList)
            {
                <div class="col-lg-6 col-xl-4">
                    <div class="card h-100 shadow-sm border-0 position-relative overflow-hidden transition">
                        <div class="position-absolute top-0 end-0 p-3">
                            <span class="badge bg-secondary">ID: @kategorija.Id</span>
                        </div>

                        <div class="card-body pb-2">
                            <div class="text-center mb-3">
                                <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #198754, #0dcaf0); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto; color: white; font-size: 1.5rem;">
                                    <i class="bi bi-tags"></i>
                                </div>
                            </div>

                            <h5 class="card-title fw-bold mb-2 text-center" style="color: #2c3e50;">
                                @kategorija.Naziv
                            </h5>

                            <p class="card-text text-muted small text-center mb-3">@kategorija.Opis</p>

                            <div class="text-center">
                                <span class="badge bg-light text-dark">
                                    <i class="bi bi-box"></i> @(kategorija.Proizvodi?.Count ?? 0) Proizvoda
                                </span>
                            </div>
                        </div>

                        <div class="card-footer bg-light border-0 p-3">
                            <a href="@Url.Action("Details", "Kategorije", new { id = kategorija.Id })" class="btn btn-sm btn-primary w-100">
                                <i class="bi bi-eye"></i> Pogledaj Kategoriju
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition { transition: all 0.3s ease; }
    .card:hover { transform: translateY(-8px); box-shadow: 0 12px 28px rgba(0, 0, 0, 0.15) !important; }
</style>
