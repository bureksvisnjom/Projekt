@model IEnumerable<OcjenjivanjeTrgovina.Models.Proizvod>

@{
    ViewData["Title"] = "Proizvodi";
    var proizvodiList = Model.ToList();
}

<div class="container-fluid py-5">
    <!-- Header Section -->
    <div class="row mb-5">
        <div class="col-lg-8">
            <h1 class="display-4 fw-bold mb-2">
                <i class="bi bi-box"></i> Proizvodi
            </h1>
            <p class="text-muted fs-5">Pregledajte sve dostupne proizvode s informacijama o cijeni i dostupnosti</p>
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="input-group input-group-lg">
                <span class="input-group-text bg-light border-0">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" class="form-control form-control-lg border-start-0" 
                       placeholder="Pretraži proizvode po imenu..." id="searchInput">
            </div>
        </div>
        <div class="col-md-6">
            <select class="form-select form-select-lg" id="filterStatus">
                <option value="">Svi proizvodi</option>
                <option value="dostupan">Dostupni</option>
                <option value="nedostupan">Nije dostupno</option>
            </select>
        </div>
    </div>

    <!-- Empty State -->
    @if (!proizvodiList.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-inbox" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Nema dostupnih proizvoda</h4>
        </div>
    }
    else
    {
        <!-- Cards Grid -->
        <div class="row g-4" id="productsGrid">
            @foreach (var proizvod in proizvodiList)
            {
                <div class="col-lg-6 col-xl-4 proizvod-card" data-naziv="@proizvod.Naziv.ToLower()" data-dostupan="@(proizvod.Dostupan ? "dostupan" : "nedostupan")">
                    <div class="card h-100 shadow-sm border-0 position-relative overflow-hidden transition">
                        <!-- Badge -->
                        <div class="position-absolute top-0 end-0 p-3">
                            @if (proizvod.Dostupan)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i> Dostupan
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-x-circle"></i> Nije dostupno
                                </span>
                            }
                        </div>

                        <!-- Card Body -->
                        <div class="card-body pb-2">
                            <h5 class="card-title fw-bold mb-2" style="color: #2c3e50;">
                                <i class="bi bi-box text-primary"></i> @proizvod.Naziv
                            </h5>

                            <p class="card-text text-muted small mb-3">@proizvod.Opis</p>

                            <div class="mb-3">
                                <span class="badge bg-light text-dark">
                                    <i class="bi bi-tag"></i> Kategorija ID: @proizvod.KategorijId
                                </span>
                            </div>

                            <p class="mb-3">
                                <i class="bi bi-tag-fill text-warning"></i>
                                <span class="fw-bold fs-5">@proizvod.Cijena.ToString("F2")€</span>
                            </p>

                            <p class="small text-muted mb-0">
                                <i class="bi bi-building"></i>
                                Trgovina ID: @proizvod.TrgovinaId
                            </p>
                        </div>

                        <!-- Card Footer -->
                        <div class="card-footer bg-light border-0 p-3">
                            <a href="@Url.Action("Details", "Proizvodi", new { id = proizvod.Id })" class="btn btn-sm btn-primary w-100">
                                <i class="bi bi-eye"></i> Pogledaj Detalje
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition { transition: all 0.3s ease; }
    .card:hover { transform: translateY(-8px); box-shadow: 0 12px 28px rgba(0, 0, 0, 0.15) !important; }
</style>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', filterProducts);
        document.getElementById('filterStatus').addEventListener('change', filterProducts);

        function filterProducts() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const statusFilter = document.getElementById('filterStatus').value;
            const cards = document.querySelectorAll('.proizvod-card');

            cards.forEach(card => {
                const naziv = card.getAttribute('data-naziv');
                const dostupan = card.getAttribute('data-dostupan');

                const matchesSearch = naziv.includes(searchTerm);
                const matchesStatus = statusFilter === '' || dostupan === statusFilter;

                card.style.display = matchesSearch && matchesStatus ? '' : 'none';
            });
        }
    </script>
}
